# Docker Container Prefix
CONTAINER_PREFIX=bks

# Application Configuration
APP_NAME=BekiApp
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=bks-mysql
DB_PORT=3306
DB_DATABASE=bks_db
DB_USERNAME=bks_user
DB_PASSWORD=bks_pass
# Root password for the MySQL container — keep distinct from DB_PASSWORD and
# change it before any non-local use.
DB_ROOT_PASSWORD=bks_root_pass

# Redis Configuration
REDIS_HOST=bks-redis
REDIS_PORT=6379

# Sanctum SPA Auth (cookie-based)
# Frontend origin(s) that receive stateful session cookies. In production set
# this to your SPA host and set SESSION_DOMAIN to the shared parent domain
# (e.g. SANCTUM_STATEFUL_DOMAINS=app.example.com, SESSION_DOMAIN=.example.com).
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DRIVER=database
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax
# Set true behind HTTPS (production)
SESSION_SECURE_COOKIE=false

# Node / Next.js Configuration
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
